#!/usr/bin/env bash
set -euo pipefail

COMMANDS="
  epic list|get|create|update|delete
  feature list|get|create|update|delete
  pi list|get|create|update|delete
  art list|get|create|assign|unassign
  team list|get
  backlog list|export
  capacity list|set
"

if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
  cat <<'EOF'
kvasar - Kvasar CLI wrapper for Claude Code plugin

Available command groups:
COMMANDS_PLACEHOLDER

Examples:
  kvasar epic list
  kvasar epic get KV-100
  kvasar feature create --title "..."
EOF
  exit 0
fi

if command -v kvasar >/dev/null 2>&1; then
  exec kvasar "$@"
fi

echo "[kvasar wrapper] Executable 'kvasar' not found in PATH:" >&2
echo "  Would run: kvasar $*" >&2
exit 1
